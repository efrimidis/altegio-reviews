# --- Altegio (reviews + booking) ---
ALTEGIO_BEARER_TOKEN=        # partner token
ALTEGIO_USER_TOKEN=          # user token (reviews only)
ALTEGIO_COMPANY_ID=          # location id used for the reviews widget

# --- Telegram (daily free-slots post) ---
# Create a bot via @BotFather, add it as an admin to the channel.
TELEGRAM_BOT_TOKEN=          # e.g. 123456:AA...
TELEGRAM_CHANNEL_ID=         # @public_channel or numeric -100... id

# --- Optional ---
PUBLISH_SECRET=              # protects GET /publish-slots (recommended in prod)
REVIEWS_COUNT=20
CACHE_TTL_MINUTES=10
REQUEST_TIMEOUT_SECONDS=10
